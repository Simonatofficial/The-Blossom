# Optional cloud sync (V2 §1). Used only if you wire these into your host's
# environment-variable injection; the browser app reads window.BLOSSOM_CONFIG
# (see config.example.js). The Blossom works fully offline without any of this.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: show a "Support on Ko-fi" button in Settings → About.
KOFI_HANDLE=
